{
  "name": "@opuspopuli/regions",
  "version": "1.0.58",
  "description": "Declarative region configuration files for Opus Populi civic data platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./regions/*": "./regions/*"
  },
  "bin": {
    "region-cli": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "regions",
    "schema"
  ],
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/cli/index.ts",
    "test": "jest --testPathIgnorePatterns=connectivity",
    "test:connectivity": "jest --testPathPattern=connectivity",
    "test:all": "jest",
    "lint": "eslint .",
    "lint:sonar": "eslint .",
    "jscpd": "jscpd",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.ts": [
      "pnpm lint"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpusPopuli/opuspopuli-regions.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "AGPL-3.0",
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "ollama": "^0.6.3"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jscpd": "^4.1.0",
    "lint-staged": "^15.2.10",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
